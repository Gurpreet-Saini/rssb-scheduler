generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  displayName String
  role        String   @default("CENTER_ADMIN") // SUPER_ADMIN or CENTER_ADMIN
  centerId    String?
  center      Center?  @relation(fields: [centerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  savedSchedules SavedSchedule[]

  @@index([centerId])
}

model Center {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String   @default("C") // SP, SC, or C
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  pathis         Pathi[]
  savedSchedules SavedSchedule[]
}

model Pathi {
  id        String   @id @default(uuid())
  name      String
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  slots     String   @default("[\"A\",\"B\",\"C\"]") // JSON array of eligible slots
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
}

model SavedSchedule {
  id           String   @id @default(uuid())
  name         String
  centerId     String
  center       Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleData String // JSON - the full GeneratedSchedule data
  pathiConfig  String // JSON - the pathis and baalSatsangGhars used
  excelData    String? // JSON - original parsed Excel data (optional, for regeneration)
  createdAt    DateTime @default(now())

  @@index([centerId])
  @@index([userId])
}
